{
  "site_name": "Synapse Vault",
  "metadata": {
    "link": "https://synapse-vault.wal.app",
    "image_url": "https://synapse-vault.wal.app/favicon.svg",
    "description": "Autonomous AI treasury management on Sui — hire an agent, set a spend cap, revoke in one click.",
    "project_url": "https://github.com/SuyashAlphaC/synapse-vault",
    "creator": "Synapse Labs"
  },
  "routes": {
    "/": "/index.html",
    "/index.html": "/index.html",
    "/styles.css": "/styles.css",
    "/calculator.js": "/calculator.js",
    "/performance.js": "/performance.js",
    "/scroll-reveal.js": "/scroll-reveal.js",
    "/favicon.svg": "/favicon.svg",
    "/index.json": "/index.json",
    "/conservative-rebalancer.json": "/conservative-rebalancer.json",
    "/balanced-yield.json": "/balanced-yield.json",
    "/aggressive-momentum.json": "/aggressive-momentum.json"
  },
  "headers": {
    "/": {
      "Content-Type": "text/html; charset=utf-8",
      "Cache-Control": "public, max-age=300, stale-while-revalidate=3600"
    },
    "/index.html": {
      "Content-Type": "text/html; charset=utf-8",
      "Cache-Control": "public, max-age=300, stale-while-revalidate=3600"
    },
    "/styles.css": {
      "Content-Type": "text/css; charset=utf-8",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/calculator.js": {
      "Content-Type": "application/javascript; charset=utf-8",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/performance.js": {
      "Content-Type": "application/javascript; charset=utf-8",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/scroll-reveal.js": {
      "Content-Type": "application/javascript; charset=utf-8",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/favicon.svg": {
      "Content-Type": "image/svg+xml",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    "/index.json": {
      "Content-Type": "application/json; charset=utf-8",
      "Cache-Control": "public, max-age=3600"
    },
    "/conservative-rebalancer.json": {
      "Content-Type": "application/json; charset=utf-8",
      "Cache-Control": "public, max-age=3600"
    },
    "/balanced-yield.json": {
      "Content-Type": "application/json; charset=utf-8",
      "Cache-Control": "public, max-age=3600"
    },
    "/aggressive-momentum.json": {
      "Content-Type": "application/json; charset=utf-8",
      "Cache-Control": "public, max-age=3600"
    }
  }
}
